---
import { coreTechnologies } from '../configs';
---
<section class="mb-24 pt-12 flex flex-col-reverse md:flex-row items-center md:items-start justify-between gap-12">
	<div class="flex-1">
		<p class="text-emerald-400 font-medium mb-4 tracking-wide uppercase text-sm">Hi, I'm Bohdan Mykhats</p>
		<h1 class="text-5xl md:text-7xl font-bold tracking-tight mb-6">
			Full-Stack Engineer <br class="hidden md:block" /> & <span class="text-emerald-400">System Architect.</span>
		</h1>
		<p class="text-slate-400 text-lg md:text-xl max-w-2xl leading-relaxed">
			Focused on high-performance web applications, 3D graphics, and scalable architecture. Building premium, high-speed digital experiences.
		</p>
		<div class="mt-8 flex gap-4">
			<a href="mailto:contact@example.com" class="px-6 py-3 bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 rounded-lg font-medium hover:bg-emerald-500/20 hover:border-emerald-500/50 transition-all duration-300">
				Get in Touch
			</a>
			<a href="#projects" class="px-6 py-3 bg-white/5 text-white border border-white/10 rounded-lg font-medium hover:bg-white/10 transition-all duration-300">
				View Work
			</a>
		</div>

		<div class="mt-16">
			<p class="text-sm text-slate-500 mb-6 uppercase tracking-wider font-medium">Core Technologies</p>
			<div class="flex flex-wrap gap-6 items-center opacity-70">
				{coreTechnologies.map(tech => (
					<img 
						src={tech.icon} 
						alt={tech.name} 
						class="h-8 w-8 grayscale hover:grayscale-0 hover:opacity-100 hover:scale-110 transition-all duration-500 cursor-help" 
						title={tech.name} 
					/>
				))}
			</div>
		</div>
	</div>

	<!-- Profile Picture -->
	<div class="shrink-0 relative group">
		<div class="absolute -inset-1 bg-liear-to-r from-emerald-500 to-blue-500 rounded-3xl blur opacity-25 group-hover:opacity-50 transition duration-1000 group-hover:duration-200"></div>
		<img 
			src="/profile.jpg" 
			alt="Bohdan Mykhats" 
			class="relative w-48 h-48 md:w-64 md:h-64 rounded-3xl object-cover border border-white/10 bg-white/5"
			onerror="this.src='https://ui-avatars.com/api/?name=Bohdan+Mykhats&size=256&background=0a0a0a&color=34d399'"
		/>
	</div>
</section>
