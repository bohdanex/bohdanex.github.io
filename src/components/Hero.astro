---
import { coreTechnologies } from '../configs';
import '../styles/hero.css';
---
<section id="about" class="mb-24 pt-12 flex flex-col-reverse md:flex-row items-center md:items-start justify-between gap-12 min-h-[calc(100vh-8rem)] md:min-h-[calc(100vh-12rem)] relative pb-20 md:pb-32">
	<div class="flex-1 flex flex-col justify-center">
		<div class="animate-fade-in">
			<p class="text-emerald-400 font-medium mb-4 tracking-wide uppercase text-sm">Hi, I'm Bohdan Mykhats</p>
			<h1 class="text-5xl md:text-7xl font-bold tracking-tight mb-6">
				Full-Stack Engineer <br class="hidden md:block" /> & <span class="text-emerald-400">System Architect.</span>
			</h1>
			<p class="text-slate-400 text-lg md:text-xl max-w-2xl leading-relaxed">
				Senior Full-Stack Engineer and System Architect with 5+ years of software engineering experience. Focused on architecting high-performance web applications, scalable distributed backend systems, and interactive 3D graphics engines. Proven track record of leading development teams, translating business requirements into technical architectures, and delivering robust, cloud-native solutions.
			</p>
			<div class="mt-8 flex flex-wrap gap-4">
				<a href="mailto:bodiamykhats@gmail.com" target="_blank" class="px-6 py-3 bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 rounded-lg font-medium hover:bg-emerald-500/20 hover:border-emerald-500/50 transition-all duration-300 animate-neon-glitch">
					Get in Touch
				</a>
				<a 
					href="/cv.pdf" 
					download="Bohdan Mykhats - Senior Full-Stack Engineer CV.pdf"
					class="px-6 py-3 bg-white/5 text-white border border-white/10 rounded-lg font-medium hover:bg-white/10 transition-all duration-300 flex items-center gap-2 group/cv"
				>
					<span>Download CV</span>
					<svg class="w-4 h-4 text-emerald-400 transition-transform group-hover/cv:translate-y-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
					</svg>
				</a>
			</div>
		</div>

		<div class="mt-16">
			<p class="text-sm text-slate-500 mb-6 uppercase tracking-wider font-medium animate-slide-down" style="animation-delay: 300ms;">Core Technologies</p>
			<div class="flex flex-wrap gap-6 items-center opacity-70">
				{coreTechnologies.map((tech, index) => {
					const levitateDuration = 3 + (index % 3);
					const levitateDelay = index * 0.15;
					return (
						<div class="animate-jump" style={`animation-delay: ${500 + index * 50}ms;`}>
							<img 
								src={tech.icon} 
								alt={tech.name} 
								class="h-8 w-8 grayscale hover:grayscale-0 hover:opacity-100 hover:scale-110 transition-all duration-500 cursor-help hover:animate-[none!important]" 
								style={`--lev-dur: ${levitateDuration}s; --lev-del: ${1100 + levitateDelay * 1000}ms;`}
								title={tech.name} 
							/>
						</div>
					);
				})}
			</div>
		</div>
	</div>

	<!-- Profile Picture -->
	<div class="shrink-0 relative group animate-fade-in" style="animation-delay: 200ms;">
		<div class="absolute -inset-1 bg-linear-to-r from-emerald-500 to-blue-500 rounded-3xl blur opacity-25 group-hover:opacity-50 transition duration-1000 group-hover:duration-200"></div>
		<img 
			src="/profile.jpg" 
			alt="Bohdan Mykhats" 
			class="relative w-48 h-48 md:w-64 md:h-64 rounded-3xl object-cover border border-white/10 bg-white/5"
			onerror="this.src='https://ui-avatars.com/api/?name=Bohdan+Mykhats&size=256&background=0a0a0a&color=34d399'"
		/>
	</div>
	<!-- Scroll Down Button (PC only) -->
	<a 
		id="scroll-down-btn"
		href="#projects" 
		class="hidden md:flex absolute bottom-12 left-1/2 -translate-x-1/2 flex-col items-center gap-3 text-slate-500 hover:text-emerald-400 transition-all duration-300 group opacity-0 pointer-events-none transition-opacity"
	>
		<span class="text-[10px] uppercase tracking-[0.2em] font-bold opacity-0 group-hover:opacity-100 transition-all duration-300 -translate-y-2 group-hover:translate-y-0">Explore Projects</span>
		<div class="w-10 h-10 rounded-full border border-white/10 bg-white/5 flex items-center justify-center group-hover:border-emerald-500/50 group-hover:bg-emerald-500/10 transition-all duration-300 group-hover:shadow-[0_0_20px_rgba(16,185,129,0.2)]">
			<svg class="w-5 h-5 transition-transform duration-300 group-hover:translate-y-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
			</svg>
		</div>
	</a>
</section>

<script>
	function updateScrollButtonVisibility() {
		const hero = document.getElementById('about');
		const btn = document.getElementById('scroll-down-btn');
		
		if (hero && btn) {
			// Show button only if hero is shorter than viewport
			// Adding a small buffer for better UX
			if (hero.offsetHeight < window.innerHeight - 50) {
				btn.classList.remove('opacity-0', 'pointer-events-none');
				btn.classList.add('opacity-100');
			} else {
				btn.classList.add('opacity-0', 'pointer-events-none');
				btn.classList.remove('opacity-100');
			}
		}
	}

	// Initialize
	updateScrollButtonVisibility();
	// Update on resize
	window.addEventListener('resize', updateScrollButtonVisibility);
	// Handle view transitions
	document.addEventListener('astro:after-swap', updateScrollButtonVisibility);
</script>

<style>
	/* Styles for Hero component */
</style>
