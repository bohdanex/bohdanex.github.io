---
import type { Project } from '../types';

interface Props extends Project {
	hasContent?: boolean;
}
const { name, description, stack, links, company, isNDA, hasContent: hasContentProp } = Astro.props;

// Helper to handle company logic
const companyName = typeof company === 'string' ? company : company?.name;
const companyLogo = typeof company === 'object' ? company?.logo : null;

// Check if the component has children passed into it (or via prop)
const hasContent = hasContentProp !== undefined ? hasContentProp : Astro.slots.has('default');
const Wrapper = hasContent ? 'details' : 'div';
const Header = hasContent ? 'summary' : 'div';
---
<Wrapper class={`group project-card bg-white/1 border border-white/5 rounded-xl transition-all duration-300 ${hasContent ? '[&_summary::-webkit-details-marker]:hidden open:bg-white/2' : 'hover:bg-white/2 hover:border-white/10'}`}>
	<Header class={`p-6 flex flex-col md:flex-row md:items-start justify-between gap-4 ${hasContent ? 'cursor-pointer list-none hover:bg-white/3 hover:border-emerald-500/20 rounded-xl transition-all duration-300' : ''}`}>
		<div class="flex-1">
			<div class="flex items-center flex-wrap gap-3 mb-2">
				<h3 class={`text-xl font-medium text-white transition-colors ${hasContent ? 'group-hover:text-emerald-300' : ''}`}>{name}</h3>
				{isNDA && (
					<div class="flex items-center gap-1.5 px-2 py-0.5 bg-amber-500/10 border border-amber-500/20 rounded text-[10px] font-bold text-amber-400 uppercase tracking-wider">
						<svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
						</svg>
						NDA
					</div>
				)}
				{companyName && (
					<div class="flex items-center gap-2 px-1.5 py-1 bg-emerald-500/10 border border-emerald-500/20 rounded-full text-xs font-medium text-emerald-300">
						{companyLogo && <img src={companyLogo} alt={companyName} class="w-4 h-4 object-contain rounded-full bg-white/10" />}
						<span>{companyName}</span>
					</div>
				)}
			</div>
			{description && <p class="text-slate-400 text-sm mb-3 max-w-3xl leading-relaxed">{description}</p>}
			<div class="flex flex-wrap gap-2 mt-2">
				{stack.map(tech => (
					<span class="px-2.5 py-1 bg-white/5 text-slate-300 text-xs rounded-md border border-white/10">
						{tech.trim()}
					</span>
				))}
			</div>
		</div>
		<div class="flex gap-3 shrink-0 items-center md:mt-0 mt-4">
			{links && (
				<div class="flex gap-3 mr-2">
					{links.map(link => (
						<a href={link.url} target="_blank" class="text-sm font-medium text-emerald-400 hover:text-emerald-300 transition-colors px-4 py-2 bg-emerald-500/10 rounded-lg hover:bg-emerald-500/20" onclick="event.stopPropagation()">
							{link.text} &rarr;
						</a>
					))}
				</div>
			)}
			{hasContent && (
				<div class="w-8 h-8 rounded-full bg-white/5 flex items-center justify-center text-slate-400 group-hover:bg-emerald-500/20 group-hover:text-emerald-400 transition-colors ml-auto md:ml-0">
					<svg class="w-5 h-5 transform transition-transform duration-500 group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
					</svg>
				</div>
			)}
		</div>
	</Header>
	{hasContent && (
		<div class="expandable-content grid grid-rows-[0fr] group-open:grid-rows-[1fr] transition-[grid-template-rows] duration-500 ease-in-out">
			<div class="overflow-hidden">
				<div class="p-6 pt-2 border-t border-white/5 text-slate-300">
					<slot />
				</div>
			</div>
		</div>
	)}
</Wrapper>

<style>
	.project-card.closing .expandable-content {
		grid-template-rows: 0fr;
	}
	.project-card.closing svg {
		transform: rotate(0deg);
	}
</style>

<script>
	function initProjectCards() {
		document.querySelectorAll('details.project-card').forEach(element => {
			const details = element as HTMLDetailsElement;
			const summary = details.querySelector('summary');
			if (!summary) return;

			summary.addEventListener('click', (e) => {
				if (details.open) {
					// Closing animation
					e.preventDefault();
					details.classList.add('closing');
					
					// Wait for transition (500ms)
					setTimeout(() => {
						details.open = false;
						details.classList.remove('closing');
					}, 500);
				}
			});
		});
	}

	// Initialize on page load
	initProjectCards();
	
	// Handle view transitions if enabled
	document.addEventListener('astro:after-swap', initProjectCards);
</script>
