---
import type { RDItem } from '../types';

interface Props {
  rdItems: RDItem[];
}
const { rdItems } = Astro.props;
---
<section id="rd" class="mb-24">
	<h2 class="text-3xl font-bold tracking-tight mb-4">R&D & High-Performance Engineering</h2>
	<div class="space-y-4">
		{rdItems.map(item => (
			<details class="rd-card group bg-white/1 border border-white/5 hover:border-white/10 rounded-xl transition-all duration-300 open:bg-white/2 [&_summary::-webkit-details-marker]:hidden">
				<summary class="p-6 cursor-pointer list-none flex items-center justify-between gap-4">
					<div>
						<h3 class="text-lg font-bold text-white leading-tight group-hover:text-emerald-400 transition-colors">{item.title}</h3>
						<p class="text-sm text-slate-400 mt-1">{item.subtitle}</p>
					</div>
					<div class="chevron-icon w-8 h-8 rounded-full bg-white/5 flex items-center justify-center text-slate-400 group-hover:bg-emerald-500/20 group-hover:text-emerald-400 transition-colors shrink-0">
						<svg class="w-5 h-5 transform transition-transform duration-500 group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
						</svg>
					</div>
				</summary>
				
				<div class="expandable-content grid grid-rows-[0fr] group-open:grid-rows-[1fr] transition-[grid-template-rows] duration-500 ease-in-out">
					<div class="overflow-hidden">
						<div class="p-6 pt-0 border-t border-white/5">
							<div class="grid grid-cols-1 md:grid-cols-2 gap-8 py-6">
								{/* Column 1: The Mission */}
								<div>
									<h4 class="text-xs font-bold text-slate-500 uppercase tracking-widest mb-3">The Mission</h4>
									<p class="text-slate-300 text-[15px] leading-relaxed">
										{item.description}
									</p>
									{item.capabilities && (
										<div class="mt-4">
											<h5 class="text-xs font-semibold text-slate-500 mb-2">Key Capabilities:</h5>
											<div class="flex flex-wrap gap-x-3 gap-y-1 text-xs text-slate-400">
												{item.capabilities.map(cap => (
													<span class="flex items-center gap-1">
														<span class="w-1 h-1 bg-emerald-500/50 rounded-full"></span>
														{cap}
													</span>
												))}
											</div>
										</div>
									)}
								</div>

								{/* Column 2: Key Results */}
								{item.metrics && (
									<div class="bg-emerald-500/5 p-5 rounded-xl border border-emerald-500/10 self-start">
										<h4 class="text-xs font-bold text-emerald-500/70 uppercase tracking-widest mb-3 text-center md:text-left">Key Results</h4>
										<p class="text-emerald-400 font-bold text-lg leading-snug text-center md:text-left">
											{item.metrics}
										</p>
									</div>
								)}
							</div>

							{/* Bottom Row: Stack */}
							<div class="flex flex-wrap gap-2 mt-2 pt-6 border-t border-white/5">
								{item.stack.map(tech => (
									<span class="px-2 py-0.5 bg-white/5 text-slate-300 text-[10px] font-bold rounded uppercase tracking-wider border border-white/10">
										{tech}
									</span>
								))}
							</div>
						</div>
					</div>
				</div>
			</details>
		))}
	</div>
</section>

<style>
	/* Print Requirements */
	@media print {
		details.rd-card {
			display: block !important;
			border: 1px solid #e5e7eb !important;
			border-left: 4px solid #10b981 !important;
			page-break-inside: avoid;
			background-color: #f9fafb !important;
		}
		summary.p-6 {
			cursor: default !important;
		}
		.chevron-icon {
			display: none !important;
		}
		.expandable-content {
			grid-template-rows: 1fr !important;
			display: block !important;
		}
		.expandable-content > div {
			overflow: visible !important;
		}
		.p-6.pt-0 {
			border-top: 1px solid #e5e7eb !important;
		}
		.rd-card h3, .rd-card h4, .rd-card h5, .rd-card p, .rd-card span {
			color: #111827 !important;
		}
		.rd-card .text-emerald-400, .rd-card .text-emerald-700 {
			color: #047857 !important;
		}
	}

	/* Smooth Closing Trick */
	details.rd-card.closing .expandable-content {
		grid-template-rows: 0fr;
	}
	details.rd-card.closing svg {
		transform: rotate(0deg);
	}
</style>

<script>
	function initRDAccordion() {
		document.querySelectorAll('details.rd-card').forEach(element => {
			const details = element as HTMLDetailsElement;
			const summary = details.querySelector('summary');
			if (!summary) return;

			summary.addEventListener('click', (e) => {
				if (details.open) {
					// Closing animation
					e.preventDefault();
					details.classList.add('closing');
					
					// Wait for transition (500ms)
					setTimeout(() => {
						details.open = false;
						details.classList.remove('closing');
					}, 500);
				}
			});
		});
	}

	// Initialize
	initRDAccordion();
	document.addEventListener('astro:after-swap', initRDAccordion);
</script>
