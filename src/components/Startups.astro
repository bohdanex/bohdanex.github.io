---
import type { Startup } from '../types';

interface Props {
	startups: Startup[];
}
const { startups } = Astro.props;
---
<section id="startups" class="mb-24">
	<h2 class="text-3xl font-bold tracking-tight mb-4">Startups</h2>
	<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
		{startups.map(startup => (
			<article class="p-8 bg-linear-to-b from-white/4 to-transparent border border-white/10 rounded-3xl hover:border-emerald-500/40 hover:from-white/8 transition-all duration-300 group flex flex-col">
				<div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-4 mb-4">
					<div>
						<h3 class="text-2xl font-semibold mb-1 text-white group-hover:text-emerald-300 transition-colors">{startup.name}</h3>
						{startup.role && <p class="text-emerald-500/80 text-sm font-medium">{startup.role}</p>}
					</div>
					{startup.status && (
						<span class="px-3 py-1 bg-white/5 border border-white/10 rounded-full text-xs text-slate-300 font-medium whitespace-nowrap self-start">
							{startup.status}
						</span>
					)}
				</div>
				<p class="text-slate-400 leading-relaxed mt-2 flex-1">
					{startup.description}
				</p>
				{startup.links && startup.links.length > 0 && (
					<div class="mt-6 flex flex-wrap gap-4">
						{startup.links.map(link => (
							<a href={link.url} data-umami-event={`Startup ${startup.name} - ${link.text}`} class="text-sm font-medium text-emerald-400 hover:text-emerald-300 flex items-center gap-1.5 transition-colors">
								{link.text}
								<svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
							</a>
						))}
					</div>
				)}
			</article>
		))}
	</div>
</section>
