---
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="dark scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<!-- Inter Font -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
		<title>{title}</title>

		<meta name="title" content={title} />
		<meta name="description" content="Expert in Angular, .NET, and 3D WebGL development. Founder of Maplyx and Castan. Building scalable system architectures and high-performance web applications." />
		<meta name="keywords" content="Software Engineer, System Architect, Angular, .NET, Three.js, WebGL, Maplyx, Ukraine, Full-Stack Developer" />
		<meta name="author" content="Bohdan" />
		
		<!-- Google Search Console Verification -->
		<meta name="google-site-verification" content="WVWMmgGYRoCWutPw44-YR1WDjBRGfMVp2bGPbDFn2Yg" />

		<link rel="canonical" href="https://bohdanex.github.io/" />
	</head>
	<body class="bg-[#0a0a0a] text-slate-50 font-['Inter',sans-serif] antialiased selection:bg-emerald-500/30 selection:text-emerald-200 overflow-x-hidden">
		<div class="relative min-h-screen">
			<!-- Subtle Background Glow -->
			<div class="absolute top-0 left-0 w-full h-[500px] bg-emerald-900/10 blur-[120px] pointer-events-none rounded-full"></div>
			<div class="relative z-10 max-w-5xl mx-auto px-6 py-16 md:py-24">
				<slot />
			</div>
		</div>
	</body>
</html>
