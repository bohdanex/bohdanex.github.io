---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Skills from '../components/Skills.astro';
import Startups from '../components/Startups.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Education from '../components/Education.astro';
import Footer from '../components/Footer.astro';
import WebBlenderProject from '../components/projects/WebBlenderProject.astro';
import WebDesignProject from '../components/projects/WebDesignProject.astro';
import WebWalkthroughProject from '../components/projects/WebWalkthroughProject.astro';
import { projects, startups, education, skills } from "../configs";
---

<Layout title="Bohdan | Full-Stack Software Engineer & System Architect">
	<main>
		<Hero />
		<Skills skills={skills} />
		<Startups startups={startups} />
		
		<section id="projects" class="mb-24">
			<h2 class="text-3xl font-bold tracking-tight mb-8">Professional Projects</h2>
			<div class="flex flex-col gap-4">
				{projects.map(project => {
					const isBlender = project.name === "Web Mini-Blender";
					const isDesign = project.name === "3D Property App (Architecture & Design Editor)";
					const isWalkthrough = project.name === "3D Walkthrough & VR Presentation Creator";
					const hasContent = isBlender || isDesign || isWalkthrough;
					return (
						<ProjectCard 
							name={project.name}
							description={project.description}
							stack={project.stack}
							links={project.links}
							company={project.company}
							hasContent={hasContent}
							isNDA={project.isNDA}
						>
							{isBlender && <WebBlenderProject />}
							{isDesign && <WebDesignProject />}
							{isWalkthrough && <WebWalkthroughProject />}
						</ProjectCard>
					);
				})}
			</div>
		</section>

		<Education education={education} />
	</main>
	<Footer />
</Layout>
